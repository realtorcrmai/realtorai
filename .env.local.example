# ─────────────────────────────────────────────────────────────────
#  Realtors360 CRM — Environment Variables Template
#
#  Copy this file to .env.local and fill in your values.
#  .env.local is gitignored. NEVER commit it.
#
#  For the canonical list of which values to use for dev vs prod,
#  see docs/ENVIRONMENTS.md.
#
#  Fastest way to get a working .env.local: run
#      vercel env pull .env.local --environment=preview
#  from a machine logged into the Vercel CLI. That writes the
#  current Preview-environment values (which match the shared dev
#  Supabase project and the rest of the dev stack) straight to the
#  file. No manual editing needed.
#
#  Alternative: ./scripts/vault.sh decrypt — decrypts .env.vault if
#  you have the team passphrase. ⚠️ As of 2026-04-09 the vault is
#  stale (last re-encrypted 2026-04-01, before the Supabase
#  consolidation). Don't use it until someone re-encrypts with the
#  current values.
# ─────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────
# Current dev project: qcohfohjihazivkforsj ("realtyaicontent")
# Dashboard: https://supabase.com/dashboard/project/qcohfohjihazivkforsj
# There is no separate prod Supabase project yet — same one for both.
NEXT_PUBLIC_SUPABASE_URL=https://qcohfohjihazivkforsj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste-from-vercel-env-pull-or-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<paste-from-vercel-env-pull-or-dashboard>

# Only needed if you run migrations via scripts/apply-newsletter-migrations.mjs
# Generate at https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=<your-personal-access-token>

# ── NextAuth (required) ──────────────────────────────────────────
# NEXTAUTH_URL must match the URL the app is actually served from.
#   Local:       http://localhost:3000
#   Dev preview: https://realestate-crm-git-dev-amandhindsas-projects.vercel.app
#   Production:  https://realestate-crm-jade-ten.vercel.app
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>

# ── Google OAuth ─────────────────────────────────────────────────
# Calendar sync + "Sign in with Google". Configured at:
#   https://console.cloud.google.com/apis/credentials
# NOTE: the Google OAuth client only has redirect URLs for the prod
# URL by default. If you want Google login to work on a preview URL
# (e.g. the dev branch deploy), you must add that preview URL to the
# "Authorized redirect URIs" list in Google Cloud Console:
#   https://<your-preview-url>/api/auth/callback/google
# Demo login (DEMO_EMAIL/DEMO_PASSWORD) works without this.
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>

# ── Twilio (SMS/WhatsApp for showings notifications) ─────────────
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_PHONE_NUMBER=+16045550100
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Anthropic Claude (AI features: content, MLS remarks, agent) ──
ANTHROPIC_API_KEY=<anthropic-api-key>

# ── Resend (transactional email + newsletter engine) ─────────────
RESEND_API_KEY=<resend-api-key>
RESEND_FROM_EMAIL=onboarding@resend.dev
# RESEND_WEBHOOK_SECRET=<for-webhook-signature-verification>

# ── App URL (callbacks, emails, etc.) ────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Demo login (shortcut for local dev + preview) ────────────────
DEMO_EMAIL=demo@realestatecrm.com
DEMO_PASSWORD=demo1234

# ── Cron secret (protects /api/cron/* endpoints) ─────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=<cron-secret>

# ── Voice Agent (optional, local Python server) ──────────────────
NEXT_PUBLIC_VOICE_AGENT_URL=http://127.0.0.1:8768

# ── BC Forms Python server (optional, local Python server) ───────
FORM_SERVER_URL=http://127.0.0.1:8767

# ── Kling AI (optional, video/image generation) ──────────────────
# KLING_API_BASE_URL=
# KLING_IMAGE_API_BASE_URL=
