# ─────────────────────────────────────────────────────────────────
#  RealtorAI BC — Environment Variables
#  Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────

# Supabase (required) — create project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth (required) — generate a random secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-min-32-chars

# Google OAuth (for Calendar + Login) — create at console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twilio (for SMS/WhatsApp showings notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+16045550100
TWILIO_WHATSAPP_NUMBER=+14155238886

# Claude AI (for AI-generated MLS remarks)
CLAUDE_API_KEY=your-claude-api-key

# App URL (used for callbacks, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret (for securing /api/reminders/check in production)
CRON_SECRET=your-cron-secret-min-32-chars

# Email (for reminder notifications — Resend or SendGrid)
RESEND_API_KEY=your-resend-api-key
# Or use SendGrid instead:
# SENDGRID_API_KEY=your-sendgrid-api-key

# Voice Agent (external voice AI integration — default: local, change for cloud deployments)
NEXT_PUBLIC_VOICE_AGENT_URL=http://127.0.0.1:8768

# BC Forms Python server (default: local, change for cloud deployments)
FORM_SERVER_URL=http://127.0.0.1:8767
