# ═══════════════════════════════════════════════════════════════
#  Voice Agent Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Agent mode: "realtor" (admin assistant) or "client" (public-facing)
AGENT_MODE=realtor

# Ollama model (must be pulled first: ollama pull llama3.2:8b)
OLLAMA_MODEL=llama3.2:8b
OLLAMA_URL=http://localhost:11434

# Whisper STT model size
WHISPER_MODEL=large-v3

# Piper TTS voice
PIPER_VOICE=en_US-amy-medium

# Daily.co WebRTC (free tier — get API key at https://dashboard.daily.co)
DAILY_API_KEY=
DAILY_ROOM_URL=

# Voice Agent HTTP port (text/API mode)
VOICE_AGENT_PORT=8768

# ListingFlow API (main server)
LISTINGFLOW_API=http://127.0.0.1:8767

# Realtor ID (matches ListingFlow agent config)
REALTOR_ID=R001

# Google Calendar (optional — for tour scheduling)
GOOGLE_CALENDAR_CREDS=credentials.json
