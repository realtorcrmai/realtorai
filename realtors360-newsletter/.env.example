# Realtors360 Newsletter Engine v3 — environment variables
# Copy this file to .env and fill in real values for local dev.
# In production, set these via the Render dashboard.

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Supabase (shared with realestate-crm — same project)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis — Upstash free tier recommended
# Format: rediss://default:<password>@<region>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# AI providers
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Email sending (M1: stay on onboarding@resend.dev — sends only to CANARY_TO_EMAIL)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_WEBHOOK_SECRET=

# Inter-service auth
# CRM signs POST /events requests with HMAC-SHA256 using this secret
NEWSLETTER_SHARED_SECRET=

# Feature flags (per-pipeline)
FLAG_SAVED_SEARCH=on
FLAG_RAG_BACKFILL=off   # M3-B: enable weekly rag embeddings backfill (Voyage cost incurred)
FLAG_WEEKLY_LEARNING=off # M3-C: enable weekly adaptive learning cycle (DB-only, no API cost)
FLAG_AGENT_SCORING=off  # M3-D: enable 15-min lead-scoring cron (Anthropic per contact, real cost)
CRM_CRON_ENABLED=true   # M3: parallel-run safety flag while migrating CRM crons

# Canary
CANARY_TO_EMAIL=amandhindsa@outlook.com
DEMO_REALTOR_ID=7de22757-dd3a-4a4f-a088-c422746e88d4
TEST_CONTACT_ID=0922c152-09a4-4430-93c2-bba05ebda674
