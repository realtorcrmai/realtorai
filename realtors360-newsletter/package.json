{
  "name": "realtors360-newsletter",
  "version": "0.1.0",
  "private": true,
  "description": "Realtors360 Newsletter Engine v3 — long-running Node service for the AI newsletter pipeline (web + worker + cron)",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "cron:dev": "tsx watch src/cron.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "cron": "node dist/cron.js",
    "test": "vitest",
    "canary": "tsx scripts/send-canary.ts",
    "seed:saved-search": "tsx scripts/seed-saved-search.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@react-email/components": "0.0.31",
    "@react-email/render": "1.0.3",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.21.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^4.0.0",
    "voyageai": "^0.0.3-5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
